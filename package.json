{
  "name": "jewelry-fullstack",
  "version": "1.0.0",
  "scripts": {
    "install-all": "npm install && cd jewelry-project/backend && npm install && cd ../frontend && npm install",
    "dev-backend": "cd jewelry-project/backend && npm run dev",
    "dev-frontend": "cd jewelry-project/frontend && npm run dev",
    "dev": "concurrently \"npm run dev-backend\" \"npm run dev-frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "cloudinary": "^1.41.3",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "react": "^19.2.4",
    "tailwindcss": "^4.2.2"
  }
}
